{
  "name": "@web3auth/mcp-server",
  "version": "2.0.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "web3auth-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "dev:http": "next dev --webpack",
    "build:all": "tsc && next build --webpack"
  },
  "keywords": [
    "web3auth",
    "metamask",
    "embedded-wallets",
    "mcp",
    "ai"
  ],
